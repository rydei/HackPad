{
    "manufacturer": "Rishu",
    "keyboard_name": "hackpad",
    "maintainer": "rydei",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "usb": {
        "vid": "0xFEED",
        "pid": "0x0000",
        "device_version": "1.0.0"
    },
    "diode_direction": "COL2ROW",
    "matrix_pins": {
    	"cols": ["GP26", "GP27", "GP28", "GP4"],
    	"rows": ["GP0", "GP29"]
    },
    "encoder": {
        "rotary": [
            { "pin_a": "GP2", "pin_b": "GP1", "resolution": 4 }
        ]
    },
    "features": {
        "bootmagic": true,
        "encoder": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
           	{"matrix": [0, 3], "x": 3.25, "y": 0.5},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1}
            ]
        }
    }
}